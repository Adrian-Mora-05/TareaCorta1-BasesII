{
  "name": "restaurant-api",
  "version": "1.0.0",
  "type": "module",
  "dependencies": {
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-jwt": "^8.5.1",
    "jose": "^4.14.4",
    "jwks-rsa": "^2.0.4",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
