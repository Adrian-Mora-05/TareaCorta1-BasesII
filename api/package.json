{
  "name": "restaurant-api",
  "version": "1.0.0",
  "type": "module",
  "dependencies": {
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-jwt": "^8.5.1",
    "ioredis": "^5.10.1",
    "jose": "^4.14.4",
    "jwks-rsa": "^2.0.4",
    "mongoose": "^9.4.1",
    "pg": "^8.20.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@jest/globals": "^29.7.0",
    "babel-jest": "^29.7.0",
    "jest": "^29.7.0",
    "supertest": "^7.0.0"
  },
  "scripts": {
    "start": "node src/app.js",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage",
    "test:unit": "node --experimental-vm-modules node_modules/jest/bin/jest.js tests/unit --coverage",
    "test:integration": "node --experimental-vm-modules node_modules/jest/bin/jest.js tests/integration --coverage"
  },
  "jest": {
    "testEnvironment": "node",
    "transform": {},
    "setupFiles": [
      "./jest.setup.js"
    ],
    "coverageThreshold": {
      "global": {
        "lines": 90,
        "functions": 90,
        "branches": 70,
        "statements": 90
      }
    },
    "collectCoverageFrom": [
      "src/controllers/**/*.js",
      "src/services/**/*.js",
      "src/middlewares/**/*.js"
    ]
  }
}
